{
    "name": "FluxusLedger Devcontainer",
    "build": {
        "dockerfile": "Dockerfile"
    },
    "workspaceFolder": "/workspaces/FluxusLedger",
    "remoteUser": "vscode",
    "forwardPorts": [
        8000,
        3000
    ],
    "postCreateCommand": "python3 -m pip install --upgrade pip && pip3 install -r backend/requirements.txt || true && cd frontend && npm install || true",
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "esbenp.prettier-vscode",
                "dbaeumer.vscode-eslint",
                "eg2.vscode-npm-script",
                "ms-azuretools.vscode-docker"
            ]
        }
    }
}
