# Database settings
DB_USER=fluxusledger_user
DB_PASSWORD=strong_password_123
DB_NAME=fluxusledger_db

# Port configuration (change these if ports are already in use on host machine)
BACKEND_PORT=8000
FRONTEND_PORT=3000
DB_PORT=5432
NGINX_PORT=80
NGINX_HTTPS_PORT=443

# API URL for frontend
# When running locally, use http://localhost:{BACKEND_PORT}
# When running behind a reverse proxy or in production, adjust accordingly
API_URL=http://localhost:8000

# JWT and security
SECRET_KEY=your-secret-key-here-change-in-production-at-least-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=60
